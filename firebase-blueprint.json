{
  "entities": {
    "UserPreferences": {
      "title": "UserPreferences",
      "description": "User preferences, showActualName toggle, and onboarding state",
      "type": "object",
      "properties": {
        "showActualName": {
          "type": "boolean",
          "description": "Whether to show the user's real name or Chief"
        },
        "onboarded": {
          "type": "boolean",
          "description": "Onboarding completed status"
        },
        "isDemoMode": {
          "type": "boolean",
          "description": "Active demo mode state"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of the last update"
        }
      },
      "required": [
        "showActualName",
        "onboarded",
        "isDemoMode"
      ]
    },
    "LedgerData": {
      "title": "LedgerData",
      "description": "Main financial data payload including accounts, debts, bills, and history",
      "type": "object",
      "properties": {
        "accounts": {
          "type": "array",
          "description": "List of bank accounts and credit lines"
        },
        "debts": {
          "type": "array",
          "description": "List of liabilities and priorities"
        },
        "bills": {
          "type": "array",
          "description": "Upcoming bills and income elements"
        },
        "goals": {
          "type": "array",
          "description": "Active savings and net worth goals"
        },
        "history": {
          "type": "array",
          "description": "Activity ledger of payments and imports"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of the last database sync"
        }
      }
    },
    "CommunityProfile": {
      "title": "CommunityProfile",
      "description": "Public visual community profile for optional peer-network accountability",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID matching request auth uid"
        },
        "username": {
          "type": "string",
          "description": "Public editable username"
        },
        "displayName": {
          "type": "string",
          "description": "Google Profile display name"
        },
        "photoURL": {
          "type": "string",
          "description": "Google Profile avatar image URL"
        },
        "level": {
          "type": "integer",
          "description": "XP Level of the user"
        },
        "xp": {
          "type": "integer",
          "description": "Current XP progress"
        },
        "lifetimeXp": {
          "type": "integer",
          "description": "Lifetime XP accumulated"
        },
        "weeklyXp": {
          "type": "integer",
          "description": "Weekly XP accumulated"
        },
        "monthlyXp": {
          "type": "integer",
          "description": "Monthly XP accumulated"
        },
        "selectedTitle": {
          "type": "string",
          "description": "Active motivational title displayed publicly"
        },
        "unlockedTitles": {
          "type": "array",
          "description": "List of unlocked user titles"
        },
        "streakCount": {
          "type": "integer",
          "description": "Daily habit checking streak"
        },
        "earnedBadges": {
          "type": "array",
          "description": "Earned reward badges"
        },
        "pinnedBadges": {
          "type": "array",
          "description": "Up to 3 badges pinned to main profile"
        },
        "optedIn": {
          "type": "boolean",
          "description": "Opt-in status for the community network"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of last profile edit"
        }
      },
      "required": [
        "uid",
        "username",
        "level",
        "xp",
        "optedIn"
      ]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "Public post celebrating achievements or sharing habit goals",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Post UUID"
        },
        "authorId": {
          "type": "string",
          "description": "User ID of the poster"
        },
        "authorName": {
          "type": "string",
          "description": "Visible display name of the poster"
        },
        "authorAvatar": {
          "type": "string",
          "description": "Avatar of the author"
        },
        "authorTitle": {
          "type": "string",
          "description": "Active title of the author"
        },
        "authorLevel": {
          "type": "integer",
          "description": "XP Level of the author"
        },
        "content": {
          "type": "string",
          "description": "Text content of the milestone share"
        },
        "achievementType": {
          "type": "string",
          "description": "Category of celebration (e.g., Debt Payoff, Savings Streak)"
        },
        "badgeId": {
          "type": "string",
          "description": "Optional associated badge ID displayed on post"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Post creation ISO timestamp"
        },
        "likes": {
          "type": "array",
          "description": "User IDs who liked this post"
        },
        "commentsCount": {
          "type": "integer",
          "description": "Total count of comments"
        }
      },
      "required": [
        "id",
        "authorId",
        "authorName",
        "content",
        "timestamp"
      ]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserPreferences",
      "description": "User preferences and setup flags"
    },
    "users/{userId}/data/ledger": {
      "schema": "LedgerData",
      "description": "Complete financial cockpit ledger payload"
    },
    "community_profiles/{userId}": {
      "schema": "CommunityProfile",
      "description": "Optional public profile for support networks"
    },
    "community_posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Community posts shared by opted-in members"
    }
  }
}
